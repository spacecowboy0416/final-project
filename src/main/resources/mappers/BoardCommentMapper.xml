<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.finalproject.coordi.board.mapper.BoardCommentMapper">

    <!-- ========================= -->
    <!-- 댓글 등록 -->
    <!-- ========================= -->
    <!--
        - 게시글(post_id)에 댓글 생성
        - 로그인 사용자(user_id) 기준으로 작성
    -->
    <insert id="insertBoardComment">
        INSERT INTO board_comment (
            post_id,
            user_id,
            content
        ) VALUES (
            #{postId},
            #{userId},
            #{content}
        )
    </insert>

    <!-- ========================= -->
    <!-- 댓글 목록 조회 -->
    <!-- ========================= -->
    <!--
        - 게시글 상세 페이지에서 사용
        - 삭제되지 않은 댓글만 조회
        - 작성자 nickname 포함
    -->
    <select id="findCommentsByPostId" resultType="BoardCommentRow">
        SELECT
            bc.comment_id,
            bc.post_id,
            bc.user_id,
            u.nickname,
            bc.content,
            bc.created_at,
            bc.updated_at
        FROM board_comment bc
        JOIN users u ON u.user_id = bc.user_id
        WHERE bc.post_id = #{postId}
          AND bc.deleted_at IS NULL
        ORDER BY bc.created_at ASC
    </select>

    <!-- ========================= -->
    <!-- 댓글 작성자 조회 -->
    <!-- ========================= -->
    <!--
        - 댓글 삭제 시 권한 체크용
    -->
    <select id="findCommentAuthorId" resultType="long">
        SELECT user_id
        FROM board_comment
        WHERE comment_id = #{commentId}
          AND deleted_at IS NULL
    </select>

    <!-- ========================= -->
    <!-- 댓글이 속한 게시글 ID 조회 -->
    <!-- ========================= -->
    <!--
        - 댓글 삭제 후 comment_count 감소 처리용
    -->
    <select id="findPostIdByCommentId" resultType="long">
        SELECT post_id
        FROM board_comment
        WHERE comment_id = #{commentId}
          AND deleted_at IS NULL
    </select>

    <!-- ========================= -->
    <!-- 댓글 존재 여부 -->
    <!-- ========================= -->
    <!--
        - 존재하지 않는 댓글 접근 방지
    -->
    <select id="existsComment" resultType="int">
        SELECT COUNT(*)
        FROM board_comment
        WHERE comment_id = #{commentId}
          AND deleted_at IS NULL
    </select>
    
    <!-- ========================= -->
    <!-- 댓글 수정 -->
    <!-- ========================= -->
    <!--
        - 댓글 내용 수정
        - 삭제되지 않은 댓글만 수정
        - 수정 시간(updated_at) 갱신
    -->
    <update id="updateBoardComment">
        UPDATE board_comment
        SET content = #{content},
            updated_at = CURRENT_TIMESTAMP
        WHERE comment_id = #{commentId}
          AND deleted_at IS NULL
    </update>

    <!-- ========================= -->
    <!-- 댓글 소프트 삭제 -->
    <!-- ========================= -->
    <!--
        - 실제 삭제가 아니라 deleted_at으로 처리
    -->
    <update id="softDeleteComment">
        UPDATE board_comment
        SET deleted_at = CURRENT_TIMESTAMP
        WHERE comment_id = #{commentId}
          AND deleted_at IS NULL
    </update>

    <!-- ========================= -->
    <!-- 게시글의 댓글 전체 소프트 삭제 -->
    <!-- ========================= -->
    <!--
        - 게시글 삭제 시 연결된 댓글도 함께 deleted_at 처리
    -->
    <update id="softDeleteCommentsByPostId">
        UPDATE board_comment
        SET deleted_at = CURRENT_TIMESTAMP
        WHERE post_id = #{postId}
          AND deleted_at IS NULL
    </update>

    <!-- ========================= -->
    <!-- 댓글 수 증가 -->
    <!-- ========================= -->
    <!--
        - 댓글 작성 시 board_post.comment_count +1
    -->
    <update id="increaseCommentCount">
        UPDATE board_post
        SET comment_count = comment_count + 1
        WHERE post_id = #{postId}
          AND deleted_at IS NULL
    </update>

    <!-- ========================= -->
    <!-- 댓글 수 감소 -->
    <!-- ========================= -->
    <!--
        - 댓글 삭제 시 board_post.comment_count -1
        - 0 이하로 내려가지 않도록 보호
    -->
    <update id="decreaseCommentCount">
        UPDATE board_post
        SET comment_count =
            CASE
                WHEN comment_count > 0 THEN comment_count - 1
                ELSE 0
            END
        WHERE post_id = #{postId}
          AND deleted_at IS NULL
    </update>

</mapper>